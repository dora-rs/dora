get_filename_component(PACKAGE_PREFIX_DIR "${CMAKE_CURRENT_LIST_DIR}/../../.." ABSOLUTE)

# Target matching check
set(DORA_BUILT_TARGET "@TARGET@")

if(CMAKE_SYSTEM_NAME STREQUAL "Windows")
    set(DORA_CURRENT_TARGET "windows-${CMAKE_SYSTEM_PROCESSOR}")
elseif(CMAKE_SYSTEM_NAME STREQUAL "Darwin")
    set(DORA_CURRENT_TARGET "macos-${CMAKE_SYSTEM_PROCESSOR}")
elseif(CMAKE_SYSTEM_NAME STREQUAL "Linux")
    set(DORA_CURRENT_TARGET "linux-${CMAKE_SYSTEM_PROCESSOR}")
else()
    message(FATAL_ERROR "dora-node-api-c: unsupported platform ${CMAKE_SYSTEM_NAME}")
endif()

message(STATUS "dora-node-api-c: built for ${DORA_BUILT_TARGET}, current is ${DORA_CURRENT_TARGET}")

if(NOT DORA_CURRENT_TARGET STREQUAL DORA_BUILT_TARGET)
    message(FATAL_ERROR "dora-node-api-c: target mismatch! built for ${DORA_BUILT_TARGET}, but current is ${DORA_CURRENT_TARGET}")
endif()

if(NOT TARGET dora-node-api-c::dora-node-api-c)
    add_library(dora-node-api-c::dora-node-api-c STATIC IMPORTED)
    
    if(WIN32)
        set(_lib_name "dora_node_api_c.lib")
    else()
        set(_lib_name "libdora_node_api_c.a")
    endif()
    
    set_target_properties(dora-node-api-c::dora-node-api-c PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/include"
        IMPORTED_LOCATION "${PACKAGE_PREFIX_DIR}/lib/${_lib_name}"
    )
endif()

# Platform-specific system libraries
if(NOT TARGET dora-node-api-c::extra)
    add_library(dora-node-api-c::extra INTERFACE IMPORTED)
    
    if(WIN32)
        target_link_libraries(dora-node-api-c::extra INTERFACE
            advapi32 userenv kernel32 ws2_32 bcrypt ncrypt schannel ntdll iphlpapi
            cfgmgr32 credui crypt32 cryptnet fwpuclnt gdi32 msimg32 mswsock ole32
            oleaut32 opengl32 secur32 shell32 synchronization user32 winspool)
    elseif(APPLE)
        target_link_libraries(dora-node-api-c::extra INTERFACE
            "-framework CoreServices" "-framework Security"
            pthread m c resolv)
    elseif(CMAKE_SYSTEM_NAME STREQUAL "Linux")
        target_link_libraries(dora-node-api-c::extra INTERFACE
            pthread dl m rt)
    endif()
endif()
