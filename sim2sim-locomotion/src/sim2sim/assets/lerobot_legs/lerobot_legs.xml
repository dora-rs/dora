<!--
  lerobot_legs: a simplified 12-DOF bipedal "legs" robot used as a bundled,
  dependency-free stand-in for the LeRobot Humanoid legs platform
  (https://huggingface.co/blog/VirgileBatto/lerobot-humanoid). Joint topology
  mirrors a standard 3D-gait biped (2 legs x {hip yaw, hip roll, hip pitch,
  knee, ankle pitch, ankle roll}), so observation/action dimensions match a real
  humanoid-legs policy. For a high-fidelity study, drop the real
  lerobot-humanoid-model MJCF into assets/ and point the robot config at it.

  Canonical joint order (must match configs/robot/lerobot_legs.yaml):
    L_hip_yaw L_hip_roll L_hip_pitch L_knee L_ankle_pitch L_ankle_roll
    R_hip_yaw R_hip_roll R_hip_pitch R_knee R_ankle_pitch R_ankle_roll
-->
<mujoco model="lerobot_legs">
  <compiler angle="radian"/>
  <option timestep="0.005" gravity="0 0 -9.81" integrator="implicitfast"/>

  <default>
    <joint armature="0.02" damping="0.5" limited="true" range="-2.6 2.6"/>
    <geom contype="1" conaffinity="1" friction="1.0 0.1 0.1" rgba="0.55 0.57 0.62 1"/>
    <motor ctrllimited="false"/>
  </default>

  <worldbody>
    <light name="top" pos="0 0 2"/>
    <geom name="floor" type="plane" size="0 0 0.1" pos="0 0 0" rgba="0.3 0.3 0.35 1"
          contype="1" conaffinity="1" friction="1.0 0.1 0.1"/>

    <body name="pelvis" pos="0 0 0.62">
      <freejoint name="root"/>
      <geom name="pelvis" type="box" size="0.08 0.10 0.07" mass="8.0"/>

      <!-- ============================ LEFT leg ============================ -->
      <body name="L_hip_yaw" pos="0 0.085 -0.05">
        <joint name="L_hip_yaw" axis="0 0 1"/>
        <geom type="sphere" size="0.04" mass="0.8"/>
        <body name="L_hip_roll" pos="0 0 0">
          <joint name="L_hip_roll" axis="1 0 0"/>
          <geom type="sphere" size="0.035" mass="0.6"/>
          <body name="L_hip_pitch" pos="0 0 0">
            <joint name="L_hip_pitch" axis="0 1 0"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.24" size="0.03" mass="2.0"/>
            <body name="L_knee" pos="0 0 -0.24">
              <joint name="L_knee" axis="0 1 0" range="0 2.6"/>
              <geom type="capsule" fromto="0 0 0 0 0 -0.24" size="0.026" mass="1.4"/>
              <body name="L_ankle_pitch" pos="0 0 -0.24">
                <joint name="L_ankle_pitch" axis="0 1 0"/>
                <geom type="sphere" size="0.03" mass="0.3"/>
                <body name="L_ankle_roll" pos="0 0 0">
                  <joint name="L_ankle_roll" axis="1 0 0"/>
                  <geom name="L_foot" type="box" pos="0.03 0 -0.04" size="0.10 0.045 0.02" mass="0.6"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- ============================ RIGHT leg =========================== -->
      <body name="R_hip_yaw" pos="0 -0.085 -0.05">
        <joint name="R_hip_yaw" axis="0 0 1"/>
        <geom type="sphere" size="0.04" mass="0.8"/>
        <body name="R_hip_roll" pos="0 0 0">
          <joint name="R_hip_roll" axis="1 0 0"/>
          <geom type="sphere" size="0.035" mass="0.6"/>
          <body name="R_hip_pitch" pos="0 0 0">
            <joint name="R_hip_pitch" axis="0 1 0"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.24" size="0.03" mass="2.0"/>
            <body name="R_knee" pos="0 0 -0.24">
              <joint name="R_knee" axis="0 1 0" range="0 2.6"/>
              <geom type="capsule" fromto="0 0 0 0 0 -0.24" size="0.026" mass="1.4"/>
              <body name="R_ankle_pitch" pos="0 0 -0.24">
                <joint name="R_ankle_pitch" axis="0 1 0"/>
                <geom type="sphere" size="0.03" mass="0.3"/>
                <body name="R_ankle_roll" pos="0 0 0">
                  <joint name="R_ankle_roll" axis="1 0 0"/>
                  <geom name="R_foot" type="box" pos="0.03 0 -0.04" size="0.10 0.045 0.02" mass="0.6"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="L_hip_yaw"     joint="L_hip_yaw"     gear="1"/>
    <motor name="L_hip_roll"    joint="L_hip_roll"    gear="1"/>
    <motor name="L_hip_pitch"   joint="L_hip_pitch"   gear="1"/>
    <motor name="L_knee"        joint="L_knee"        gear="1"/>
    <motor name="L_ankle_pitch" joint="L_ankle_pitch" gear="1"/>
    <motor name="L_ankle_roll"  joint="L_ankle_roll"  gear="1"/>
    <motor name="R_hip_yaw"     joint="R_hip_yaw"     gear="1"/>
    <motor name="R_hip_roll"    joint="R_hip_roll"    gear="1"/>
    <motor name="R_hip_pitch"   joint="R_hip_pitch"   gear="1"/>
    <motor name="R_knee"        joint="R_knee"        gear="1"/>
    <motor name="R_ankle_pitch" joint="R_ankle_pitch" gear="1"/>
    <motor name="R_ankle_roll"  joint="R_ankle_roll"  gear="1"/>
  </actuator>
</mujoco>
