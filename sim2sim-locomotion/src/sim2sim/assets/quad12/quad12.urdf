<?xml version="1.0"?>
<!--
  quad12 URDF for PyBullet. Same 12-DOF topology and link geometry as
  quad12.xml (MuJoCo) so the SAME policy faces the same robot in both sims.
  Joint order matches configs/robot/quad12.yaml.
-->
<robot name="quad12">

  <!-- ============================== trunk ============================== -->
  <link name="trunk">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="6.0"/>
      <inertia ixx="0.05" iyy="0.10" izz="0.12" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <collision>
      <geometry><box size="0.40 0.18 0.09"/></geometry>
    </collision>
    <visual>
      <geometry><box size="0.40 0.18 0.09"/></geometry>
    </visual>
  </link>

  <!-- Macro-free explicit legs. Pattern per leg:
       <hip_origin> hip(axis x) -> hip_link
       <0,±0.06,0>  thigh(axis y) -> thigh_link (capsule down 0.18)
       <0,0,-0.18>  calf(axis y) -> calf_link (capsule down 0.18 + foot sphere) -->

  <!-- ============================== FL ============================== -->
  <link name="FL_hip">
    <inertial><mass value="0.6"/><inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0.03 0"/><geometry><cylinder radius="0.025" length="0.06"/></geometry><origin rpy="1.5708 0 0"/></collision>
  </link>
  <link name="FL_thigh">
    <inertial><origin xyz="0 0 -0.09"/><mass value="0.9"/><inertia ixx="0.003" iyy="0.003" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0 -0.09" rpy="0 0 0"/><geometry><cylinder radius="0.022" length="0.18"/></geometry></collision>
  </link>
  <link name="FL_calf">
    <inertial><origin xyz="0 0 -0.09"/><mass value="0.45"/><inertia ixx="0.002" iyy="0.002" izz="0.0003" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0 -0.09"/><geometry><cylinder radius="0.018" length="0.18"/></geometry></collision>
    <collision><origin xyz="0 0 -0.18"/><geometry><sphere radius="0.025"/></geometry></collision>
  </link>
  <joint name="FL_hip" type="revolute">
    <parent link="trunk"/><child link="FL_hip"/>
    <origin xyz="0.18 0.09 0"/><axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>
  <joint name="FL_thigh" type="revolute">
    <parent link="FL_hip"/><child link="FL_thigh"/>
    <origin xyz="0 0.06 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>
  <joint name="FL_calf" type="revolute">
    <parent link="FL_thigh"/><child link="FL_calf"/>
    <origin xyz="0 0 -0.18"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>

  <!-- ============================== FR ============================== -->
  <link name="FR_hip">
    <inertial><mass value="0.6"/><inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 -0.03 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.025" length="0.06"/></geometry></collision>
  </link>
  <link name="FR_thigh">
    <inertial><origin xyz="0 0 -0.09"/><mass value="0.9"/><inertia ixx="0.003" iyy="0.003" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0 -0.09"/><geometry><cylinder radius="0.022" length="0.18"/></geometry></collision>
  </link>
  <link name="FR_calf">
    <inertial><origin xyz="0 0 -0.09"/><mass value="0.45"/><inertia ixx="0.002" iyy="0.002" izz="0.0003" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0 -0.09"/><geometry><cylinder radius="0.018" length="0.18"/></geometry></collision>
    <collision><origin xyz="0 0 -0.18"/><geometry><sphere radius="0.025"/></geometry></collision>
  </link>
  <joint name="FR_hip" type="revolute">
    <parent link="trunk"/><child link="FR_hip"/>
    <origin xyz="0.18 -0.09 0"/><axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>
  <joint name="FR_thigh" type="revolute">
    <parent link="FR_hip"/><child link="FR_thigh"/>
    <origin xyz="0 -0.06 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>
  <joint name="FR_calf" type="revolute">
    <parent link="FR_thigh"/><child link="FR_calf"/>
    <origin xyz="0 0 -0.18"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>

  <!-- ============================== RL ============================== -->
  <link name="RL_hip">
    <inertial><mass value="0.6"/><inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0.03 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.025" length="0.06"/></geometry></collision>
  </link>
  <link name="RL_thigh">
    <inertial><origin xyz="0 0 -0.09"/><mass value="0.9"/><inertia ixx="0.003" iyy="0.003" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0 -0.09"/><geometry><cylinder radius="0.022" length="0.18"/></geometry></collision>
  </link>
  <link name="RL_calf">
    <inertial><origin xyz="0 0 -0.09"/><mass value="0.45"/><inertia ixx="0.002" iyy="0.002" izz="0.0003" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0 -0.09"/><geometry><cylinder radius="0.018" length="0.18"/></geometry></collision>
    <collision><origin xyz="0 0 -0.18"/><geometry><sphere radius="0.025"/></geometry></collision>
  </link>
  <joint name="RL_hip" type="revolute">
    <parent link="trunk"/><child link="RL_hip"/>
    <origin xyz="-0.18 0.09 0"/><axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>
  <joint name="RL_thigh" type="revolute">
    <parent link="RL_hip"/><child link="RL_thigh"/>
    <origin xyz="0 0.06 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>
  <joint name="RL_calf" type="revolute">
    <parent link="RL_thigh"/><child link="RL_calf"/>
    <origin xyz="0 0 -0.18"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>

  <!-- ============================== RR ============================== -->
  <link name="RR_hip">
    <inertial><mass value="0.6"/><inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 -0.03 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.025" length="0.06"/></geometry></collision>
  </link>
  <link name="RR_thigh">
    <inertial><origin xyz="0 0 -0.09"/><mass value="0.9"/><inertia ixx="0.003" iyy="0.003" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0 -0.09"/><geometry><cylinder radius="0.022" length="0.18"/></geometry></collision>
  </link>
  <link name="RR_calf">
    <inertial><origin xyz="0 0 -0.09"/><mass value="0.45"/><inertia ixx="0.002" iyy="0.002" izz="0.0003" ixy="0" ixz="0" iyz="0"/></inertial>
    <collision><origin xyz="0 0 -0.09"/><geometry><cylinder radius="0.018" length="0.18"/></geometry></collision>
    <collision><origin xyz="0 0 -0.18"/><geometry><sphere radius="0.025"/></geometry></collision>
  </link>
  <joint name="RR_hip" type="revolute">
    <parent link="trunk"/><child link="RR_hip"/>
    <origin xyz="-0.18 -0.09 0"/><axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>
  <joint name="RR_thigh" type="revolute">
    <parent link="RR_hip"/><child link="RR_thigh"/>
    <origin xyz="0 -0.06 0"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>
  <joint name="RR_calf" type="revolute">
    <parent link="RR_thigh"/><child link="RR_calf"/>
    <origin xyz="0 0 -0.18"/><axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="40" velocity="30"/>
  </joint>

</robot>
