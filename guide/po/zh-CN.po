msgid "Topic publish"
msgstr "主题发布"

#: src/advanced/ros2-bridge.md:10
msgid "`topic` + `direction: publish`"
msgstr "`topic` + `direction: publish`"

#: src/advanced/ros2-bridge.md:10
msgid "Receive Arrow, publish to ROS2"
msgstr "接收 Arrow，发布到 ROS2"

