msgid "\"failed to init adora context\\n\""
msgstr "\"failed to init adora context\\n\""

#: src/languages/c.md:413
msgid "// all streams closed\n"
msgstr "// 所有流已关闭\n"

#: src/languages/c.md:422
msgid "// Send a response\n"
msgstr "// 发送响应\n"

#: src/languages/c.md:426
msgid "\"iteration %d\""
msgstr "\"iteration %d\""

#: src/languages/c.md:443
msgid "Dataflow YAML for the node:"
msgstr "节点的数据流 YAML："

#: src/languages/c.md:447
msgid "c_node"
msgstr ""

#: src/languages/c.md:448
msgid "build/c_node"
msgstr ""

#: src/languages/c.md:455
msgid "Operator Example"
msgstr "算子示例"

#: src/languages/c.md:457
msgid ""
"A complete C operator that reads input, maintains state, and sends output:"
msgstr "一个读取输入、维护状态并发送输出的完整 C 算子："

#: src/languages/c.md:460
msgid "\"operator_api.h\""
msgstr ""

#: src/languages/c.md:466
msgid "// Allocate operator state (a simple counter)\n"
msgstr "// 分配算子状态（一个简单的计数器）\n"

#: src/languages/c.md:493
msgid "\"received input '%s', counter: %d\\n\""
msgstr "\"received input '%s', counter: %d\\n\""

#: src/languages/c.md:495
msgid "// Send counter value as string\n"
msgstr "// 将计数器值作为字符串发送\n"

#: src/languages/c.md:497
